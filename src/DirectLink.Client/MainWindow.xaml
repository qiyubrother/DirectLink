<Window x:Class="DirectLink.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DirectLink 点对点传文件"
        Width="560" Height="480"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Loaded="MainWindow_Loaded">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 第一行：本机 ID、对端 ID、保存到、设置/断开 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="本机 ID：" VerticalAlignment="Center"/>
            <TextBox x:Name="TbClientId" Width="36" MaxLength="3" IsReadOnly="True" VerticalContentAlignment="Center" Padding="4,2" Background="#F0F0F0"/>
            <TextBlock Text="  对端 ID：" VerticalAlignment="Center" Margin="10,0,0,0"/>
            <TextBox x:Name="TbPeerId" Width="36" MaxLength="3" VerticalContentAlignment="Center" Padding="4,2"/>
            <TextBlock Text="  保存到：" VerticalAlignment="Center" Margin="10,0,0,0"/>
            <TextBox x:Name="TbSaveDir" MinWidth="180" VerticalContentAlignment="Center" Padding="4,2"/>
            <Button x:Name="BtnBrowseSave" Content="…" Width="28" Margin="4,0,0,0" Click="BtnBrowseSave_OnClick"/>
            <Button x:Name="BtnSettingsOrDisconnect" Content="{Binding SettingsButtonText}" Width="72" Margin="12,0,0,0" Click="BtnSettingsOrDisconnect_OnClick" ToolTip="未连接时：设置服务端地址与端口并连接；已连接时：断开"/>
        </StackPanel>

        <!-- 第二行：拖拽区 + 选择文件 + 发送 (Alt+S) -->
        <Border Grid.Row="1" BorderBrush="#CCC" BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,8"
                Background="#FAFAFA" AllowDrop="True" DragOver="DropZone_DragOver" Drop="DropZone_Drop">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TbFile" Grid.Column="0" IsReadOnly="True" VerticalContentAlignment="Center" Padding="4,2"
                         MinWidth="200" Text="{Binding SelectedSummary, Mode=OneWay}"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">
                    <Button x:Name="BtnSelectFile" Content="选择文件" Width="76" Click="BtnSelectFile_OnClick"/>
                    <Button x:Name="BtnSend" Content="发送(_S)" Width="76" Margin="8,0,0,0" Click="BtnSend_OnClick"
                            IsEnabled="{Binding IsConnected}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 状态 + 传输方式 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,4">
            <TextBlock x:Name="TbStatus" Text="{Binding StatusText}" VerticalAlignment="Center"/>
            <TextBlock VerticalAlignment="Center" Margin="8,0,0,0" Foreground="Gray" FontSize="12"
                       Text="{Binding TransferModeText, StringFormat=【{0}】}">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding TransferModeText}" Value="">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </StackPanel>

        <!-- 进度 -->
        <StackPanel Grid.Row="3" Margin="0,0,0,8">
            <TextBlock Text="{Binding TransferFileProgressText}" FontSize="11" Foreground="Gray" Margin="0,0,0,2"/>
            <ProgressBar x:Name="ProgressBar" Height="6" Minimum="0" Maximum="100" Value="{Binding ProgressPercent}"/>
            <TextBlock x:Name="TbProgressDetail" Text="{Binding ProgressDetail}" Margin="0,4,0,0" FontSize="12" Foreground="Gray"/>
        </StackPanel>

        <!-- 传输日志 -->
        <GroupBox Grid.Row="4" Header="传输日志" Padding="6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <ListView x:Name="LogList" Grid.Row="0" ItemsSource="{Binding LogEntries}"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="时间" Width="130" DisplayMemberBinding="{Binding Time, StringFormat=HH:mm:ss}"/>
                            <GridViewColumn Header="类型" Width="48" DisplayMemberBinding="{Binding Category}"/>
                            <GridViewColumn Header="内容" Width="280" DisplayMemberBinding="{Binding Message}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
                <Grid Grid.Row="1" Margin="0,6,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Button x:Name="BtnConnect" Content="连接" Width="56" Click="BtnConnect_OnClick"
                                IsEnabled="{Binding IsDisconnected}"/>
                        <Button x:Name="BtnDisconnect" Content="断开" Width="56" Margin="8,0,0,0" Click="BtnDisconnect_OnClick"
                                IsEnabled="{Binding IsConnected}"/>
                        <Button x:Name="BtnSettings" Content="设置" Width="56" Margin="8,0,0,0" Click="BtnSettings_OnClick"/>
                    </StackPanel>
                    <Button x:Name="BtnExportLog" Grid.Column="1" Content="导出日志…" Width="90" Click="BtnExportLog_OnClick"/>
                </Grid>
            </Grid>
        </GroupBox>
    </Grid>
</Window>

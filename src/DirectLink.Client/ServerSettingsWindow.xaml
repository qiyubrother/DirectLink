<Window x:Class="DirectLink.Client.ServerSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="服务器设置"
        Width="380" Height="160"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="ToolWindow">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="服务端：" VerticalAlignment="Center" Width="56"/>
            <TextBox x:Name="TbServer" MinWidth="220" VerticalContentAlignment="Center" Padding="4,2"/>
        </StackPanel>
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="本机 ID：" VerticalAlignment="Center" Width="56"/>
            <TextBox x:Name="TbClientId" Width="60" MaxLength="3" VerticalContentAlignment="Center" Padding="4,2"/>
            <TextBlock Text="（3 位数字）" VerticalAlignment="Center" Margin="6,0,0,0" Foreground="Gray"/>
        </StackPanel>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="BtnConnect" Content="连接" Width="80" Margin="0,0,8,0" Click="BtnConnect_OnClick"/>
            <Button Content="取消" Width="80" IsCancel="True" Click="BtnCancel_OnClick"/>
        </StackPanel>
    </Grid>
</Window>
